#!/usr/bin/env bash
#
# letcook — let him cook
#
# A tool-agnostic standard for running autonomous producer/evaluator loops
# with AI coding assistants.
#
# Usage:
#   letcook init [dir] [--tool <tool>]   Scaffold a new project
#   letcook run  [dir] [--tool <tool>]   Run the loop with a specific tool
#   letcook help                         Show this help message
#   letcook version                      Show version

set -euo pipefail

VERSION="0.1.0"

# --- Resolve install directory ---

# Resolve symlinks so LETCOOK_HOME points to the real install directory
REAL_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_PATH="$(cd "$(dirname "$REAL_SCRIPT")" && pwd)"
# Support both repo layout (bin/letcook → ..) and install layout (~/.letcook/bin/letcook → ~/.letcook)
LETCOOK_HOME="$(dirname "$SCRIPT_PATH")"

# --- Colors ---

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# --- Helpers ---

info()    { echo -e "${CYAN}$1${NC}"; }
success() { echo -e "${GREEN}$1${NC}"; }
warn()    { echo -e "${YELLOW}$1${NC}"; }
err()     { echo -e "${RED}$1${NC}" >&2; }

parse_frontmatter_field() {
    local file="$1" field="$2"
    sed -n '/^---$/,/^---$/p' "$file" \
        | grep -E "^${field}:" \
        | head -1 \
        | sed "s/^${field}:[[:space:]]*//" \
        | sed 's/[[:space:]]*#.*//' \
        | tr -d '[:space:]'
}

parse_program_type() {
    parse_frontmatter_field "$1" "type"
}

claude_tools_for_type() {
    local base="Read,Write,Edit,Bash,Glob,Grep,Agent"
    case "${1:-build}" in
        research)   echo "$base,WebSearch,WebFetch" ;;
        content)    echo "$base,WebSearch,WebFetch" ;;
        experiment) echo "$base,WebSearch,WebFetch,NotebookEdit" ;;
        *)          echo "$base" ;;
    esac
}

parse_goal() {
    local file="$1"
    local in_goal=false
    while IFS= read -r line; do
        if [[ "$line" =~ ^##[[:space:]]+Goal ]]; then
            in_goal=true
            continue
        fi
        if $in_goal; then
            [[ "$line" =~ ^## ]] && break
            [[ "$line" =~ ^\<\!-- ]] && continue
            [[ -z "$line" ]] && continue
            echo "$line"
            return
        fi
    done < "$file"
}

count_constraints() {
    local file="$1" section="$2"
    local in_section=false count=0
    while IFS= read -r line; do
        if [[ "$line" =~ ^##[[:space:]]+"$section" ]]; then
            in_section=true
            continue
        fi
        if $in_section; then
            [[ "$line" =~ ^## ]] && break
            [[ "$line" =~ ^\<\!-- ]] && continue
            [[ "$line" =~ ^-[[:space:]]+.+ ]] && ((count++))
        fi
    done < "$file"
    echo "$count"
}

format_elapsed() {
    local seconds="$1"
    local h=$((seconds / 3600))
    local m=$(( (seconds % 3600) / 60 ))
    local s=$((seconds % 60))
    if (( h > 0 )); then
        printf "%dh %02dm %02ds" "$h" "$m" "$s"
    elif (( m > 0 )); then
        printf "%dm %02ds" "$m" "$s"
    else
        printf "%ds" "$s"
    fi
}

parse_loop_state() {
    local file="$1"
    local iteration=0 score="-" status="ready" last_status=""
    if [ ! -f "$file" ]; then
        echo "0 - ready"
        return
    fi
    while IFS= read -r line; do
        if [[ "$line" =~ ^##[[:space:]]+Iteration[[:space:]]+([0-9]+) ]]; then
            iteration="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^\*\*Score\*\*:[[:space:]]*([0-9]+) ]]; then
            score="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^\*\*Status\*\*:[[:space:]]*(.+) ]]; then
            last_status="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^##[[:space:]]+Summary ]]; then
            last_status="done"
        fi
    done < "$file"
    status="${last_status:-running}"
    echo "$iteration $score $status"
}

print_status_box() {
    local goal="$1" prog_type="$2" tool_name="$3" iteration="$4"
    local max_iter="$5" threshold="$6" score="$7" status="$8"
    local elapsed="$9" hard="${10}" soft="${11}" output_dir="${12}"

    # Truncate goal to fit box (31 chars for the value column)
    local max_goal=31
    if (( ${#goal} > max_goal )); then
        goal="${goal:0:$((max_goal - 3))}..."
    fi

    # Status color
    local status_color="$CYAN"
    case "$status" in
        ready)              status_color="$CYAN" ;;
        running)            status_color="$YELLOW" ;;
        passed|completed)   status_color="$GREEN" ;;
        failed|exhausted)   status_color="$RED" ;;
        needs_improvement)  status_color="$YELLOW" ;;
        done)               status_color="$GREEN" ;;
    esac

    # Score display
    local score_display="$score"
    if [[ "$score" != "-" ]]; then
        score_display="${score} / ${threshold}"
    fi

    printf "\033[2J\033[H"
    echo -e "${BOLD}┌──────────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}│${NC}  ${BOLD}letcook${NC}                                     ${BOLD}│${NC}"
    echo -e "${BOLD}├──────────────────────────────────────────────┤${NC}"
    printf "${BOLD}│${NC}  Goal:        %-31s ${BOLD}│${NC}\n" "$goal"
    printf "${BOLD}│${NC}  Type:        %-31s ${BOLD}│${NC}\n" "$prog_type"
    printf "${BOLD}│${NC}  Tool:        %-31s ${BOLD}│${NC}\n" "$tool_name"
    printf "${BOLD}│${NC}  Iterations:  %-31s ${BOLD}│${NC}\n" "$iteration / $max_iter"
    printf "${BOLD}│${NC}  Score:       %-31s ${BOLD}│${NC}\n" "$score_display"
    printf "${BOLD}│${NC}  Constraints: %-31s ${BOLD}│${NC}\n" "${hard} hard · ${soft} soft"
    printf "${BOLD}│${NC}  Output:      %-31s ${BOLD}│${NC}\n" "$output_dir"
    echo -e "${BOLD}├──────────────────────────────────────────────┤${NC}"
    printf "${BOLD}│${NC}  Status:      ${status_color}%-31s${NC} ${BOLD}│${NC}\n" "$status"
    printf "${BOLD}│${NC}  Elapsed:     %-31s ${BOLD}│${NC}\n" "$elapsed"
    echo -e "${BOLD}└──────────────────────────────────────────────┘${NC}"
}

STATUS_WATCHER_PID=""

cleanup_watcher() {
    if [ -n "$STATUS_WATCHER_PID" ] && kill -0 "$STATUS_WATCHER_PID" 2>/dev/null; then
        kill "$STATUS_WATCHER_PID" 2>/dev/null
        wait "$STATUS_WATCHER_PID" 2>/dev/null
    fi
}

start_status_watcher() {
    local target_dir="$1" goal="$2" prog_type="$3" tool_name="$4"
    local max_iter="$5" threshold="$6" hard="$7" soft="$8"
    local output_dir="$9" start_time="${10}"

    (
        while true; do
            local loop_file="$target_dir/loop-state.md"
            local state
            state="$(parse_loop_state "$loop_file")"
            local iteration score status
            iteration="$(echo "$state" | cut -d' ' -f1)"
            score="$(echo "$state" | cut -d' ' -f2)"
            status="$(echo "$state" | cut -d' ' -f3-)"

            local now elapsed_str
            now="$(date +%s)"
            elapsed_str="$(format_elapsed $((now - start_time)))"

            print_status_box "$goal" "$prog_type" "$tool_name" \
                "$iteration" "$max_iter" "$threshold" "$score" "$status" \
                "$elapsed_str" "$hard" "$soft" "$output_dir"

            [[ "$status" == "done" || "$status" == "completed" || "$status" == "exhausted" ]] && break
            sleep 5
        done
    ) &
    STATUS_WATCHER_PID=$!
}

copy_if_missing() {
    local src="$1" dst="$2"
    if [ -f "$dst" ]; then
        warn "  SKIP   $dst (already exists)"
    else
        cp "$src" "$dst"
        success "  CREATE $dst"
    fi
}

# --- Commands ---

cmd_help() {
    cat <<'HELP'
letcook — let him cook

Usage:
  letcook init [dir] [--tool <tool>]   Scaffold a new project
  letcook run  [dir] [--tool <tool>]   Run the loop with a specific tool
  letcook help                         Show this help
  letcook version                      Show version

Tools:
  claude      Claude Code (slash commands + headless CLI)
  cursor      Cursor (rules file)
  windsurf    Windsurf (rules file)
  continue    Continue.dev (rules file)
  aider       Aider (config file)
  codex       OpenAI Codex CLI (prints command)
  copilot     GitHub Copilot CLI (prints command)

Examples:
  letcook init ./my-task                Scaffold with no tool integration
  letcook init ./my-task --tool claude  Scaffold + Claude Code skills
  letcook run ./my-task --tool claude   Run headless with Claude Code
  letcook run ./my-task --tool aider    Run with Aider
HELP
}

cmd_version() {
    echo "letcook $VERSION"
}

cmd_init() {
    local target_dir="."
    local tool=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --tool) tool="$2"; shift 2 ;;
            *)      target_dir="$1"; shift ;;
        esac
    done

    mkdir -p "$target_dir/specs"

    echo ""
    info "${BOLD}Initializing autonomous loop project...${NC}"
    echo ""

    # Core files
    copy_if_missing "$LETCOOK_HOME/skill.md"               "$target_dir/specs/skill.md"
    copy_if_missing "$LETCOOK_HOME/templates/program.md"    "$target_dir/specs/program.md"
    copy_if_missing "$LETCOOK_HOME/templates/restrictions.md" "$target_dir/specs/restrictions.md"

    # Tool integration
    if [ -n "$tool" ]; then
        echo ""
        install_tool_integration "$tool" "$target_dir"
    fi

    echo ""
    success "${BOLD}Project initialized in $target_dir${NC}"
    echo ""
    echo -e "Next steps:"
    echo -e "  1. Edit ${BOLD}$target_dir/specs/program.md${NC}      — define your task"
    echo -e "  2. Edit ${BOLD}$target_dir/specs/restrictions.md${NC}  — set quality gates"
    echo -e "  3. Run:  ${CYAN}letcook run $target_dir${NC}"
    echo ""
}

cmd_run() {
    local target_dir="."
    local tool=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --tool) tool="$2"; shift 2 ;;
            *)      target_dir="$1"; shift ;;
        esac
    done

    # Validate project files exist
    for file in specs/skill.md specs/program.md specs/restrictions.md; do
        if [ ! -f "$target_dir/$file" ]; then
            err "Missing $target_dir/$file"
            err "Run 'letcook init $target_dir' first."
            exit 1
        fi
    done

    local prompt="Read specs/skill.md, specs/program.md, and specs/restrictions.md, then execute the autonomous loop as defined in specs/skill.md."

    # Auto-detect tool if not specified
    local detected=""
    if [ -z "$tool" ]; then
        if command -v claude &>/dev/null; then
            tool="claude"
        elif command -v aider &>/dev/null; then
            tool="aider"
        elif command -v codex &>/dev/null; then
            tool="codex"
        elif command -v copilot &>/dev/null; then
            tool="copilot"
        fi
        if [ -n "$tool" ]; then
            detected=" (auto-detected)"
        fi
    fi

    echo ""

    # Parse project metadata for status display
    local program_file="$target_dir/specs/program.md"
    local restrictions_file="$target_dir/specs/restrictions.md"
    local program_type
    program_type="$(parse_program_type "$program_file")"
    program_type="${program_type:-build}"
    local max_iter
    max_iter="$(parse_frontmatter_field "$program_file" "iterations")"
    max_iter="${max_iter:-5}"
    local threshold
    threshold="$(parse_frontmatter_field "$program_file" "completion_threshold")"
    threshold="${threshold:-90}"
    local output_dir
    output_dir="$(parse_frontmatter_field "$program_file" "output")"
    output_dir="${output_dir:-./output/}"
    local goal
    goal="$(parse_goal "$program_file")"
    goal="${goal:-(not set)}"
    local hard soft
    hard="$(count_constraints "$restrictions_file" "Hard Constraints")"
    soft="$(count_constraints "$restrictions_file" "Soft Constraints")"

    case "$tool" in
        claude)
            local allowed_tools
            allowed_tools="$(claude_tools_for_type "$program_type")"
            local tool_label="claude${detected}"
            local start_time
            start_time="$(date +%s)"

            trap cleanup_watcher EXIT INT TERM

            start_status_watcher "$target_dir" "$goal" "$program_type" \
                "$tool_label" "$max_iter" "$threshold" "$hard" "$soft" \
                "$output_dir" "$start_time"

            cd "$target_dir"
            claude -p "$prompt" --allowedTools "$allowed_tools" > /dev/null 2>&1
            local exit_code=$?

            cleanup_watcher

            # Final status
            local state
            state="$(parse_loop_state "loop-state.md")"
            local iteration score status
            iteration="$(echo "$state" | cut -d' ' -f1)"
            score="$(echo "$state" | cut -d' ' -f2)"
            status="$(echo "$state" | cut -d' ' -f3-)"

            local end_time elapsed_str
            end_time="$(date +%s)"
            elapsed_str="$(format_elapsed $((end_time - start_time)))"

            print_status_box "$goal" "$program_type" "$tool_label" \
                "$iteration" "$max_iter" "$threshold" "$score" "$status" \
                "$elapsed_str" "$hard" "$soft" "$output_dir"

            echo ""
            if [ $exit_code -eq 0 ]; then
                success "Done."
            else
                err "Claude exited with code $exit_code"
            fi
            exit $exit_code
            ;;
        aider)
            info "Running with Aider${detected}..."
            echo ""
            exec aider \
                --read "$target_dir/specs/skill.md" \
                --read "$target_dir/specs/program.md" \
                --read "$target_dir/specs/restrictions.md" \
                --message "$prompt"
            ;;
        codex)
            info "Running with Codex CLI${detected}..."
            echo ""
            cd "$target_dir"
            exec codex exec "$prompt"
            ;;
        copilot)
            info "Running with GitHub Copilot CLI${detected}..."
            echo ""
            cd "$target_dir"
            exec copilot -p "$prompt"
            ;;
        "")
            warn "No AI tool detected. Paste this prompt into your AI assistant:"
            echo ""
            echo -e "  ${BOLD}$prompt${NC}"
            echo ""
            echo "Or install one of: claude, aider, codex, copilot"
            ;;
        *)
            err "Tool '$tool' doesn't support headless execution."
            echo ""
            echo "For $tool, open the project in your IDE and tell the AI:"
            echo ""
            echo -e "  ${BOLD}Start working on this project.${NC}"
            echo ""
            ;;
    esac
}

install_tool_integration() {
    local tool="$1"
    local target_dir="$2"

    case "$tool" in
        claude)
            mkdir -p "$target_dir/.claude/skills/start-project"
            mkdir -p "$target_dir/.claude/skills/start-working"
            copy_if_missing "$LETCOOK_HOME/integrations/claude/skills/start-project/SKILL.md" \
                           "$target_dir/.claude/skills/start-project/SKILL.md"
            copy_if_missing "$LETCOOK_HOME/integrations/claude/skills/start-working/SKILL.md" \
                           "$target_dir/.claude/skills/start-working/SKILL.md"
            ;;
        cursor)
            mkdir -p "$target_dir/.cursor/rules"
            copy_if_missing "$LETCOOK_HOME/integrations/cursor/autonomous-loop.mdc" \
                           "$target_dir/.cursor/rules/autonomous-loop.mdc"
            ;;
        windsurf)
            mkdir -p "$target_dir/.windsurf/rules"
            copy_if_missing "$LETCOOK_HOME/integrations/windsurf/autonomous-loop.md" \
                           "$target_dir/.windsurf/rules/autonomous-loop.md"
            ;;
        continue)
            mkdir -p "$target_dir/.continue/rules"
            copy_if_missing "$LETCOOK_HOME/integrations/continue/autonomous-loop.md" \
                           "$target_dir/.continue/rules/autonomous-loop.md"
            ;;
        aider)
            copy_if_missing "$LETCOOK_HOME/integrations/aider/.aider.conf.yml" \
                           "$target_dir/.aider.conf.yml"
            ;;
        *)
            warn "Unknown tool '$tool'. Skipping integration."
            echo "  Supported: claude, cursor, windsurf, continue, aider"
            ;;
    esac
}

# --- Main ---

case "${1:-help}" in
    init)    shift; cmd_init "$@" ;;
    run)     shift; cmd_run "$@" ;;
    help)    cmd_help ;;
    version) cmd_version ;;
    *)       err "Unknown command: $1"; echo ""; cmd_help; exit 1 ;;
esac
